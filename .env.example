# Copie para `.env` e ajuste. Não commite `.env` com segredos reais.

# PostgreSQL local (docker-compose): use esta URL
DATABASE_URL="postgresql://erp:erp@localhost:5432/shopping1a1?schema=public"

# Mercado Livre OAuth
MERCADOLIBRE_CLIENT_ID=""
MERCADOLIBRE_CLIENT_SECRET=""
MERCADOLIBRE_REDIRECT_URI="http://localhost:3000/api/auth/mercadolibre/callback"

# Mercado Livre API endpoints opcionais. Deixe comentado para usar os padrões oficiais.
# MERCADOLIBRE_AUTH_BASE="https://auth.mercadolivre.com.br"
# MERCADOLIBRE_API_BASE="https://api.mercadolibre.com"

# Chave para cifrar refresh/access ML em `ml_seller_credentials` (AES-256-GCM).
# Gere com: openssl rand -base64 32
ENCRYPTION_KEY=""

# Web Push / VAPID para notificações push do navegador.
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# Opcionais: usados somente pelo script de simulação do webhook de catálogo.
# CATALOG_COMPETITION_WEBHOOK_URL="http://localhost:3000/api/ml/notifications/catalog-competition"
# CATALOG_COMPETITION_ITEM_ID="MLB4561866095"
# CATALOG_COMPETITION_ML_USER_ID="1"
# CATALOG_COMPETITION_STATUS="winning"

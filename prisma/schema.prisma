// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Anúncio sincronizado do Mercado Livre (chave = ml_item_id, ex. MLB…).
model Listing {
  mlItemId       String    @id @map("ml_item_id")
  titleSnapshot  String?   @map("title_snapshot")
  skuSnapshot    String?   @map("sku_snapshot")
  imageUrlSnapshot String? @map("image_url_snapshot")
  catalogListing Boolean?  @map("catalog_listing")
  lastSyncedAt   DateTime? @map("last_synced_at")
  activeOnMl     Boolean   @default(true) @map("active_on_ml")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  warehouseStock WarehouseStock?
  competitionSnapshots CatalogCompetitionSnapshot[]
  stockAttentionAcknowledgements StockAttentionAcknowledgement[]

  @@index([activeOnMl])
  @@map("listings")
}

enum CatalogCompetitionStatus {
  winning
  losing
  shared
  unknown
}

enum CatalogCompetitionSource {
  webhook
  missed_feed
  manual_poll
}

enum StockAttentionKind {
  full
  purchase
}

model CatalogCompetitionSnapshot {
  id           String                   @id @default(cuid())
  mlItemId     String                   @map("ml_item_id")
  status       CatalogCompetitionStatus
  priceToWin   Decimal?                 @map("price_to_win") @db.Decimal(18, 2)
  snapshotAt   DateTime                 @default(now()) @map("snapshot_at")
  source       CatalogCompetitionSource @default(manual_poll)
  rawResponse  Json                     @map("raw_response")

  listing Listing @relation(fields: [mlItemId], references: [mlItemId], onDelete: Cascade)

  @@unique([mlItemId, snapshotAt])
  @@index([snapshotAt(sort: Desc)])
  @@index([mlItemId, snapshotAt(sort: Desc)])
  @@map("catalog_competition_snapshots")
}

/// Estoque físico no galpão (1:1 com listing).
model WarehouseStock {
  mlItemId              String   @id @map("ml_item_id")
  quantity              Int      @default(0)
  /// Prazo compra → chegada no galpão (dias inteiros; UI pode informar em semanas).
  purchaseLeadTimeDays  Int?     @map("purchase_lead_time_days")
  notes                 String?
  updatedAt             DateTime @updatedAt @map("updated_at")

  listing Listing @relation(fields: [mlItemId], references: [mlItemId], onDelete: Cascade)

  @@map("warehouse_stock")
}

/// Avisos de estoque que já receberam ação operacional (ex.: compra feita).
model StockAttentionAcknowledgement {
  id                   String             @id @default(cuid())
  mlItemId             String             @map("ml_item_id")
  kind                 StockAttentionKind
  mlAvailableQuantity  Int                @map("ml_available_quantity")
  warehouseQuantity    Int                @map("warehouse_quantity")
  purchaseLeadTimeDays Int?               @map("purchase_lead_time_days")
  acknowledgedAt       DateTime           @default(now()) @map("acknowledged_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  listing Listing @relation(fields: [mlItemId], references: [mlItemId], onDelete: Cascade)

  @@unique([mlItemId, kind])
  @@index([kind])
  @@map("stock_attention_acknowledgements")
}

/// Tokens OAuth do vendedor ML (até 1 linha por `ml_user_id`) para chamadas server-side (ex.: webhook).
/// `refresh_enc` / `access_enc` são texto cifrado (AES-256-GCM) com `ENCRYPTION_KEY`.
model MlSellerCredentials {
  mlUserId        Int       @id @map("ml_user_id")
  refreshEnc      String    @map("refresh_enc") @db.Text
  accessEnc       String?   @map("access_enc") @db.Text
  accessExpiresAt DateTime? @map("access_expires_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("ml_seller_credentials")
}

/// Push subscriptions Web Push por vendedor/dispositivo.
model PushSubscription {
  id         String   @id @default(cuid())
  mlUserId   Int      @map("ml_user_id")
  endpoint   String   @db.Text
  p256dh     String   @db.Text
  auth       String   @db.Text
  userAgent  String?  @map("user_agent") @db.Text
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([mlUserId, endpoint])
  @@index([mlUserId])
  @@map("push_subscriptions")
}
